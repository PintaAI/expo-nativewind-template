{
  "name": "expo-nativewind-template",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/ui": "~56.0.18",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "nativewind": "^5.0.0-preview.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-css": "^3.0.7",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-image-colors": "^2.6.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "~19.2.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "dev": "expo start --dev-client --tunnel -c",
    "start": "expo start --dev-client --tunnel",
    "start:dev": "expo start --dev-client --tunnel",
    "init-template": "node ./scripts/init-template.js",
    "android": "expo start --dev-client --tunnel --android",
    "ios": "expo start --dev-client --tunnel --ios",
    "run:android": "expo run:android",
    "build:android": "eas build --profile development --platform android --local --output ./app-dev.apk",
    "build:android:preview": "eas build --profile preview --platform android --local --output ./app-preview.apk",
    "build:ios": "eas build --profile development --platform ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "private": true,
  "overrides": {
    "lightningcss": "1.30.1"
  }
}
